# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3002,https://pmx-ai-copilot.vercel.app

# Database (M0.3)
# Point at any Postgres 15+ with pgvector 0.7+ available. Neon is the
# canonical prod target (their free tier ships pgvector).
# Any of these forms work — session.py normalises them to psycopg 3:
#   postgres://user:pass@host:5432/pmx
#   postgresql://user:pass@host:5432/pmx
#   postgresql+psycopg://user:pass@host:5432/pmx
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/pmx

# Clerk (M0.4) — issuer is the Clerk Frontend API URL for your instance.
# Example: https://curious-crab-42.clerk.accounts.dev
# CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWT_AUDIENCE=  # leave blank unless you added a custom `aud` claim in the Clerk JWT template

# Logfire (opt-in — only set both to send telemetry)
# LOGFIRE_TOKEN=
# LOGFIRE_SEND_TO_LOGFIRE=false

# LLM (M1)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Object storage (M1)
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=pmx-uploads
