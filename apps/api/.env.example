# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3002,https://pmx-ai-copilot.vercel.app

# Database (M0.3)
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/pmx

# Logfire (opt-in — only set both to send telemetry)
# LOGFIRE_TOKEN=
# LOGFIRE_SEND_TO_LOGFIRE=false

# LLM (M1)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Object storage (M1)
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=pmx-uploads
