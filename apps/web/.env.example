# Clerk (M0.4) — pull real values from https://dashboard.clerk.com/last-active?path=api-keys
#
# The dummy publishable key below decodes to a valid Clerk frontend API URL
# format, which lets `pnpm build` prerender static pages without a real Clerk
# instance. It will NOT authenticate anyone. Swap for your real key in
# `.env.local` (never commit) before running the dev server against Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZGVjZW50LWJlYWdsZS02Ni5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_replace_me

# Optional — override default Clerk sign-in / sign-up URLs.
# Defaults use the modal + hosted account portal, which is what we ship in M0.4.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
